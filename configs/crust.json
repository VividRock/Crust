{
  "Application": {
    "Name": "Crust",
    "Version": "1.2.2",
    "Company": "VividRock",
    "Copyright": "Copyright (c) 2012-2026 VividRock | All Rights Reserved",
    "Links": "https://github.com/VividRock/Crust"
  },
  "Metadata": {
    "StartDateTime": "",
    "CompleteDateTime": "",
    "CompleteTimeSpan": "",
    "ExecutionUser": "",
    "ScriptResult": "",
    "ScriptResultCode": ""
  },
  "Logging": {
    "Enabled": true,
    "Directory": "set by Invoke-CrustMenu parameter",
    "TimestampFormat": "yyyy-MM-dd_HHmmss",
    "Filename": "_Crust.log",
    "FilePath": "set by Initialize-Crust function",
    "CleanupAfterRun": false,
    "SplatParams": "set by Write-CrustLog function"
  },
  "StatusWindow": {
    "Enabled": false,
    "Console": "PowerShell",
    "identifier": "crust-status",
    "Title": "Crust  |  VividRock",
    "AlwaysOnTop": false
  },
  "Paths": {
    "LangUri": "set by Initialize-Crust function",
    "MenuUri": "set by Initialize-Crust function"
  },
  "PowerShell": {
    "MinimumVersion": "7.0.0",
    "Preferences": {
      "ErrorActionPreference": "Stop"
    }
  },
  "Settings": {
    "RunAsAdminRequired": false,
    "DebugMode": false,
    "InterfaceSleepMilliseconds": 0
  },
  "Security": {
    "Authentication": {
      "Enabled": false,
      "LaunchPoint": "AtStartup",
      "Context": "Machine",
      "Method": "Inline"
    }
  }
}
