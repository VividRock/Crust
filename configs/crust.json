{
  "Application": {
    "Name": "Crust",
    "Version": "1.2.2",
    "Company": "VividRock",
    "Copyright": "Copyright (c) 2012-2026 VividRock | All Rights Reserved",
    "Links": "https://github.com/VividRock/Crust"
  },
  "Metadata": {
    "StartDateTime": "",
    "CompleteDateTime": "",
    "CompleteTimeSpan": "",
    "ExecutionUser": "",
    "ScriptResult": "",
    "ScriptResultCode": ""
  },
  "Logging": {
    "Directory": ".\\logs\\",
    "TimestampFormat": "yyyy-MM-dd_HHmmss",
    "Filename": "_Crust.log"
  },
  "Paths": {
    "LocalPath": "set by Invoke-Crust parameter at runtime",
    "LangUri": "set by Invoke-Crust parameter at runtime",
    "MenuUri": "set by Invoke-Crust parameter at runtime"
  },
  "PowerShell": {
    "MinimumVersion": "7.0.0",
    "Preferences": {
      "ErrorActionPreference": "Stop"
    }
  },
  "Settings": {
    "RunAsAdminRequired": false,
    "DebugMode": false,
    "InterfaceSleepMilliseconds": 0
  },
  "Security": {
    "Authentication": {
      "Enabled": true,
      "LaunchPoint": "AtStartup",
      "Context": "Machine",
      "Method": "Popup"
    }
  }
}
