{
  "Application": {
    "Name": "Crust",
    "Version": "1.2.0",
    "Company": "VividRock",
    "Copyright": "Copyright (c) 2012-2026 VividRock | All Rights Reserved",
    "Links": "https://github.com/VividRock/Crust"
  },
  "Metadata": {
    "StartDateTime": "",
    "CompleteDateTime": "",
    "CompleteTimeSpan": "",
    "ExecutionUser": "",
    "ScriptResult": "",
    "ScriptResultCode": ""
  },
  "Logging": {
    "Directory": ".\\logs\\",
    "TimestampFormat": "yyyy-MM-dd_HHmmss",
    "Filename": "_Crust.log"
  },
  "Paths": {
    "Configs": ".\\configs\\",
    "Modules": ".\\modules\\",
    "Languages": ".\\lang\\"
  },
  "Preferences": {
    "ErrorActionPreference": "Stop"
  },
  "Settings": {
    "RunAsAdminRequired": false,
    "DebugMode": false,
    "InterfaceSleepMilliseconds": 0
  },
  "Security": {
    "Authentication": {
      "Enabled": true,
      "LaunchPoint": "AtStartup",
      "Context": "Machine",
      "Method": "Popup"
    }
  }
}